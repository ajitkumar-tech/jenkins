pipeline {
    agent any


    stages {

        stage('Checkout Source') {
            steps {
                git branch: 'main',                    
                    url: 'https://github.com/ajitkumar-tech/kubernetes.git'
            }
        }  

     stage('Terraform Init') {
            steps {
                sh '''
                    terraform init
                '''
            }
        }

        
        stage('Terraform Plan') {
            steps {
                sh '''
                    terraform plan 
                '''
            }
        }

        stage('Terraform Apply') {
            steps {
                
                sh '''
                    terraform destroy -auto-approve 
                '''
            }
        }       

         stage('login to ecr') {
            steps {
                sh """
                    aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin 748716953870.dkr.ecr.us-east-1.amazonaws.com
                """
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build -t docker .
                """
            }
        }

        stage('Tag Image for ECR') {
            steps {
                sh """
                    docker tag docker:latest 748716953870.dkr.ecr.us-east-1.amazonaws.com/docker:latest
                """
            }
        }

        stage('Push Image to ECR') {
            steps {
                sh """
                    docker push 748716953870.dkr.ecr.us-east-1.amazonaws.com/docker:latest
                """
            }
        }
     stage('ansible') {
            steps {
                ansiblePlaybook credentialsId: 'ansible', disableHostKeyChecking: true, installation: 'ansible', inventory: 'hosts', playbook: 'playbook.yml', vaultTmpPath: ''
            }
        }
    }
}    

        stage('deploy to ekscluster') {
            steps {
                sh """
                    aws eks update-kubeconfig --name my-eks-cluster --region us-east-1 

                    kubectl apply -f deployment.yml
                """
            }
        }  
    }
}
   
